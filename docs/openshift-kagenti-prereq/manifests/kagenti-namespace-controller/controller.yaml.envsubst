apiVersion: v1
kind: ServiceAccount
metadata:
  name: kagenti-namespace-controller
  namespace: kagenti-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: kagenti-namespace-controller
rules:
  - apiGroups: [""]
    resources: ["namespaces"]
    verbs: ["get", "list", "watch"]
  - apiGroups: [""]
    resources: ["configmaps"]
    verbs: ["get", "list", "watch", "create", "update", "patch"]
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["rbac.authorization.k8s.io"]
    resources: ["rolebindings"]
    verbs: ["get", "list", "watch", "create", "update", "patch"]
  - apiGroups: ["route.openshift.io"]
    resources: ["routes"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["security.openshift.io"]
    resources: ["securitycontextconstraints"]
    verbs: ["get", "list", "watch", "patch", "update"]
  - apiGroups: ["security.openshift.io"]
    resources: ["securitycontextconstraints"]
    resourceNames: ["kagenti-authbridge", "privileged"]
    verbs: ["use"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: kagenti-namespace-controller
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: kagenti-namespace-controller
subjects:
  - kind: ServiceAccount
    name: kagenti-namespace-controller
    namespace: kagenti-system
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: kagenti-namespace-controller
  namespace: kagenti-system
data:
  reconcile.sh: |
    #!/usr/bin/env bash
    set -euo pipefail

    KUBECTL="${KUBECTL:-kubectl}"
    KEYCLOAK_NAMESPACE="${KEYCLOAK_NAMESPACE:-${KC_NAMESPACE}}"
    KEYCLOAK_REALM="${KEYCLOAK_REALM:-${KC_REALM}}"
    POLL_INTERVAL_SECONDS="${POLL_INTERVAL_SECONDS:-30}"

    log() {
      printf '[kagenti-namespace-controller] %s\n' "$*"
    }

    get_keycloak_public_url() {
      local route_host
      route_host=$($KUBECTL get route keycloak -n "$KEYCLOAK_NAMESPACE" -o jsonpath='{.spec.host}' 2>/dev/null || true)
      if [ -n "$route_host" ]; then
        printf 'https://%s\n' "$route_host"
      else
        printf 'http://keycloak-service.%s.svc.cluster.local:8080\n' "$KEYCLOAK_NAMESPACE"
      fi
    }

    get_keycloak_admin_user() {
      local encoded
      encoded=$($KUBECTL get secret keycloak-initial-admin -n "$KEYCLOAK_NAMESPACE" -o jsonpath='{.data.username}' 2>/dev/null || true)
      if [ -n "$encoded" ]; then
        printf '%s' "$encoded" | base64 -d
      else
        printf 'admin\n'
      fi
    }

    get_keycloak_admin_pass() {
      local encoded
      encoded=$($KUBECTL get secret keycloak-initial-admin -n "$KEYCLOAK_NAMESPACE" -o jsonpath='{.data.password}' 2>/dev/null || true)
      if [ -n "$encoded" ]; then
        printf '%s' "$encoded" | base64 -d
      else
        printf 'admin\n'
      fi
    }

    sync_scc_groups() {
      local groups_json first=true namespace group
      local groups=()

      for namespace in "$@"; do
        [ -n "$namespace" ] || continue
        groups+=("system:serviceaccounts:${namespace}")
      done

      groups_json='{"groups":['
      for group in "${groups[@]}"; do
        if [ "$first" = true ]; then
          first=false
        else
          groups_json+=','
        fi
        groups_json+="\"${group}\""
      done
      groups_json+=']}'

      log "Syncing kagenti-authbridge SCC groups for ${#groups[@]} kagenti-enabled namespace(s)"
      $KUBECTL patch scc kagenti-authbridge --type=merge -p "$groups_json" >/dev/null
    }

    apply_namespace_artifacts() {
      local namespace="$1"
      local kc_internal_url kc_public_url kc_admin_user kc_admin_pass

      kc_internal_url="http://keycloak-service.${KEYCLOAK_NAMESPACE}.svc.cluster.local:8080"
      kc_public_url="$(get_keycloak_public_url)"
      kc_admin_user="$(get_keycloak_admin_user)"
      kc_admin_pass="$(get_keycloak_admin_pass)"

      cat <<EOF | $KUBECTL apply -f - >/dev/null
    apiVersion: v1
    kind: ConfigMap
    metadata:
      name: environments
      namespace: ${namespace}
    data:
      KEYCLOAK_REALM: "${KEYCLOAK_REALM}"
      KEYCLOAK_URL: "${kc_internal_url}"
      KEYCLOAK_ADMIN_USERNAME: "${kc_admin_user}"
      KEYCLOAK_ADMIN_PASSWORD: "${kc_admin_pass}"
      KEYCLOAK_TOKEN_EXCHANGE_ENABLED: "true"
      KEYCLOAK_CLIENT_REGISTRATION_ENABLED: "true"
      SPIRE_ENABLED: "true"
    ---
    apiVersion: v1
    kind: ConfigMap
    metadata:
      name: authbridge-config
      namespace: ${namespace}
    data:
      TOKEN_URL: "${kc_internal_url}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/token"
      ISSUER: "${kc_public_url}/realms/${KEYCLOAK_REALM}"
      TARGET_AUDIENCE: "auth-target"
      TARGET_SCOPES: "openid auth-target-aud"
    ---
    apiVersion: v1
    kind: ConfigMap
    metadata:
      name: envoy-config
      namespace: ${namespace}
    data:
      envoy.yaml: |
        admin:
          address:
            socket_address: { protocol: TCP, address: 127.0.0.1, port_value: 9901 }

        static_resources:
          listeners:
          - name: outbound_listener
            address:
              socket_address: { protocol: TCP, address: 0.0.0.0, port_value: 15123 }
            listener_filters:
            - name: envoy.filters.listener.original_dst
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.listener.original_dst.v3.OriginalDst
            - name: envoy.filters.listener.tls_inspector
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.listener.tls_inspector.v3.TlsInspector
            filter_chains:
            - filter_chain_match: { transport_protocol: tls }
              filters:
              - name: envoy.filters.network.tcp_proxy
                typed_config:
                  "@type": type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                  stat_prefix: outbound_tls_passthrough
                  cluster: original_destination
            - filter_chain_match: { transport_protocol: raw_buffer }
              filters:
              - name: envoy.filters.network.http_connection_manager
                typed_config:
                  "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                  stat_prefix: outbound_http
                  codec_type: AUTO
                  route_config:
                    name: outbound_routes
                    virtual_hosts:
                    - name: catch_all
                      domains: ["*"]
                      routes:
                      - match: { prefix: "/" }
                        route: { cluster: original_destination }
                  http_filters:
                  - name: envoy.filters.http.ext_proc
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.ext_proc.v3.ExternalProcessor
                      grpc_service:
                        envoy_grpc: { cluster_name: ext_proc_cluster }
                        timeout: 30s
                      processing_mode:
                        request_header_mode: SEND
                        response_header_mode: SKIP
                        request_body_mode: NONE
                        response_body_mode: NONE
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
          - name: inbound_listener
            address:
              socket_address: { protocol: TCP, address: 0.0.0.0, port_value: 15124 }
            listener_filters:
            - name: envoy.filters.listener.original_dst
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.listener.original_dst.v3.OriginalDst
            filter_chains:
            - filters:
              - name: envoy.filters.network.http_connection_manager
                typed_config:
                  "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                  stat_prefix: inbound_http
                  codec_type: AUTO
                  route_config:
                    name: inbound_routes
                    virtual_hosts:
                    - name: local_app
                      domains: ["*"]
                      request_headers_to_add:
                      - header: { key: "x-authbridge-direction", value: "inbound" }
                        append: false
                      routes:
                      - match: { prefix: "/" }
                        route: { cluster: original_destination }
                  http_filters:
                  - name: envoy.filters.http.ext_proc
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.ext_proc.v3.ExternalProcessor
                      grpc_service:
                        envoy_grpc: { cluster_name: ext_proc_cluster }
                        timeout: 30s
                      processing_mode:
                        request_header_mode: SEND
                        response_header_mode: SKIP
                        request_body_mode: NONE
                        response_body_mode: NONE
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
          clusters:
          - name: original_destination
            connect_timeout: 30s
            type: ORIGINAL_DST
            lb_policy: CLUSTER_PROVIDED
            original_dst_lb_config: { use_http_header: false }
          - name: ext_proc_cluster
            connect_timeout: 5s
            type: STATIC
            lb_policy: ROUND_ROBIN
            http2_protocol_options: {}
            load_assignment:
              cluster_name: ext_proc_cluster
              endpoints:
              - lb_endpoints:
                - endpoint:
                    address:
                      socket_address: { address: 127.0.0.1, port_value: 9090 }
    ---
    apiVersion: v1
    kind: ConfigMap
    metadata:
      name: spiffe-helper-config
      namespace: ${namespace}
    data:
      helper.conf: |
        agent_address = "/spiffe-workload-api/spire-agent.sock"
        cmd = ""
        cmd_args = ""
        svid_file_name = "/opt/svid.pem"
        svid_key_file_name = "/opt/svid_key.pem"
        svid_bundle_file_name = "/opt/svid_bundle.pem"
        jwt_svids = [{jwt_audience="kagenti", jwt_svid_file_name="/opt/jwt_svid.token"}]
        jwt_svid_file_mode = 0644
        include_federated_domains = true
    ---
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      name: agent-authbridge-scc
      namespace: ${namespace}
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: system:openshift:scc:kagenti-authbridge
    subjects:
      - kind: Group
        apiGroup: rbac.authorization.k8s.io
        name: system:serviceaccounts:${namespace}
    ---
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      name: pipeline-privileged-scc
      namespace: ${namespace}
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: system:openshift:scc:privileged
    subjects:
      - kind: ServiceAccount
        name: pipeline
        namespace: ${namespace}
    ---
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      name: openclaw-oauth-proxy-privileged-scc
      namespace: ${namespace}
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: system:openshift:scc:privileged
    subjects:
      - kind: ServiceAccount
        name: openclaw-oauth-proxy
        namespace: ${namespace}
    EOF
    }

    reconcile_namespace() {
      local namespace="$1"
      log "Reconciling namespace ${namespace}"
      apply_namespace_artifacts "$namespace"
    }

    main() {
      local namespaces=()
      local namespace

      log "Starting reconciler for namespaces labeled kagenti-enabled=true"
      while true; do
        namespaces=()
        while IFS= read -r namespace; do
          [ -n "$namespace" ] || continue
          namespaces+=("$namespace")
        done < <($KUBECTL get namespaces -l kagenti-enabled=true -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}')

        sync_scc_groups "${namespaces[@]}"

        for namespace in "${namespaces[@]}"; do
          reconcile_namespace "$namespace"
        done
        sleep "$POLL_INTERVAL_SECONDS"
      done
    }

    main
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: kagenti-namespace-controller
  namespace: kagenti-system
  labels:
    app.kubernetes.io/name: kagenti-namespace-controller
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: kagenti-namespace-controller
  template:
    metadata:
      labels:
        app.kubernetes.io/name: kagenti-namespace-controller
    spec:
      serviceAccountName: kagenti-namespace-controller
      containers:
        - name: controller
          image: quay.io/kubestellar/kubectl:1.30.14
          imagePullPolicy: IfNotPresent
          command: ["/bin/bash", "/scripts/reconcile.sh"]
          env:
            - name: KEYCLOAK_NAMESPACE
              value: "${KC_NAMESPACE}"
            - name: KEYCLOAK_REALM
              value: "${KC_REALM}"
            - name: POLL_INTERVAL_SECONDS
              value: "30"
          volumeMounts:
            - name: scripts
              mountPath: /scripts
              readOnly: true
      volumes:
        - name: scripts
          configMap:
            name: kagenti-namespace-controller
            defaultMode: 0755
